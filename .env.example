# VPS local PostgreSQL (API and DB on same Hostinger VPS)
DATABASE_URL="postgresql://travel_app:YOUR_DB_PASSWORD@127.0.0.1:5432/travel_agency?schema=public"

# Local development example:
# DATABASE_URL="postgresql://travel_app:dev123456@127.0.0.1:5432/travel_agency_dev?schema=public"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=5001
NODE_ENV=development
UPLOAD_DIR=./uploads
FRONTEND_URL=http://localhost:3000
# Public URL for logos on exported HTML (invoices, vouchers, statements). Defaults to FRONTEND_URL.
# API_PUBLIC_URL=https://travel-api.bestechvision.com

# Gmail invite emails — create App Password: Google Account → Security → 2-Step Verification → App passwords
