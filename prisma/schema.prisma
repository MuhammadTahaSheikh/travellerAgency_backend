generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  USER
}

enum AccountType {
  CASH
  BANK
  REVENUE
  CUSTOMER
  SUPPLIER
  EMPLOYEE
}

enum BookingStatus {
  DRAFT
  PENDING
  REQUEST_CONFIRMATION
  CONFIRMED
  CANCELLED
  COMPLETED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum BookingConfirmationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
  OTHER
}

enum ExpenseCategory {
  AIRLINE
  HOTEL
  VISA
  OFFICE
  SALARY
  MARKETING
  OTHER
}

enum IncomeCategory {
  PACKAGE_BOOKING
  VISA_SERVICE
  HOTEL_RESERVATION
  TICKET_SALE
  COMMISSION
  OTHER
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_CONFIRMATION_REQUEST
  PAYMENT_REMINDER
  DUE_ALERT
  CHECK_IN_REMINDER
  SYSTEM_ANNOUNCEMENT
  POSTING_REQUEST
  EMAIL
}

enum PostingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceType {
  PACKAGE
  TICKET
  VISA
  HOTEL
  TRANSPORT
  OTHER
}

enum CustomerType {
  B2C
  B2B
}

enum CurrencyCode {
  PKR
  SAR
}

enum PriceMode {
  DETERMINED
  BREAKDOWN
}

enum InvoiceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VendorPostingType {
  INSTANT
  PENDING
}

enum VendorPostingStatus {
  UNASSIGNED
  PENDING
  POSTED
  CANCELLED
}

enum VoucherFormat {
  COMPLETE
  HOTEL
  TRANSPORT
}

enum TicketTripType {
  ONE_WAY
  ROUND_TRIP
}

enum VendorCategory {
  HOTEL
  VISA
  TICKETING
  TRANSPORT
  OTHER
}

enum PaymentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum VoucherStatus {
  DRAFT
  ISSUED
  SHARED
}

enum ActivityAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
}

model Role {
  id          String           @id @default(uuid())
  name        RoleName         @unique
  description String?
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  resource    String
  action      String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean        @default(true)
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  createdById   String?
  createdBy     User?          @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers  User[]         @relation("UserCreatedBy")
  bookings      Booking[]      @relation("BookingCreatedBy")
  payments      Payment[]      @relation("PaymentRecordedBy")
  expenses      Expense[]      @relation("ExpenseCreatedBy")
  notifications Notification[]
  activityLogs  ActivityLog[]
  loginHistory  LoginHistory[]
  employeeAccount Account?     @relation("EmployeeAccount")
  inviteToken       String?   @unique
  inviteExpiresAt   DateTime?
  passwordSetAt     DateTime?
  approvedInvoices       Invoice[]        @relation("InvoiceApprovedBy")
  postingRequestsCreated PostingRequest[] @relation("PostingRequestRequestedBy")
  postingRequestsReviewed PostingRequest[] @relation("PostingRequestReviewedBy")
  bookingConfirmationRequestsCreated BookingConfirmationRequest[] @relation("BookingConfirmationRequestedBy")
  bookingConfirmationRequestsReviewed BookingConfirmationRequest[] @relation("BookingConfirmationReviewedBy")
  bookingRefundsCreated              BookingRefund[]              @relation("BookingRefundCreatedBy")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model Customer {
  id              String             @id @default(uuid())
  customerType    CustomerType       @default(B2C)
  firstName       String
  lastName        String
  companyName     String?
  contactPerson   String?
  ntn             String?
  tradePartnerId  String?            @unique
  email           String?
  phone           String
  address         String?
  city            String?
  country         String?
  passportNo      String?
  nationalId      String?
  dateOfBirth     DateTime?
  notes           String?
  isActive        Boolean            @default(true)
  documents       CustomerDocument[]
  bookings        Booking[]
  bookingCustomers BookingCustomer[]
  invoices        Invoice[]
  account         Account?           @relation("CustomerAccount")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model CustomerDocument {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String
  fileName   String
  filePath   String
  notes      String?
  uploadedAt DateTime @default(now())
}

model Package {
  id           String               @id @default(uuid())
  name         String
  description  String?
  price        Decimal              @db.Decimal(12, 2)
  duration     Int
  maxCapacity  Int                  @default(1)
  isActive     Boolean              @default(true)
  destinations PackageDestination[]
  bookings     Booking[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model PackageDestination {
  id          String  @id @default(uuid())
  packageId   String
  package     Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  destination String
  country     String?
  nights      Int     @default(1)
  order       Int     @default(0)
}

model Vendor {
  id                  String                 @id @default(uuid())
  vendorCode          String?                @unique
  name                String
  category            VendorCategory         @default(OTHER)
  contactPerson       String?
  email               String?
  phone               String?
  address             String?
  isActive            Boolean                @default(true)
  account             Account?               @relation("VendorAccount")
  serviceItems        BookingServiceItem[]
  costAllocations     VendorCostAllocation[]
  expenses            Expense[]
  vendorPostings      VendorPosting[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model Booking {
  id               String                 @id @default(uuid())
  bookingNumber    String                 @unique
  packageId        String?
  package          Package?               @relation(fields: [packageId], references: [id])
  customerId       String
  customer         Customer               @relation(fields: [customerId], references: [id])
  createdById      String
  createdBy        User                   @relation("BookingCreatedBy", fields: [createdById], references: [id])
  status           BookingStatus          @default(DRAFT)
  bookingType      CustomerType           @default(B2C)
  guestName        String?
  currency         CurrencyCode           @default(PKR)
  priceMode        PriceMode              @default(DETERMINED)
  travelDate       DateTime?
  returnDate       DateTime?
  numTravelers     Int                    @default(1)
  adults           Int                    @default(1)
  children         Int                    @default(0)
  infants          Int                    @default(0)
  priceAdult       Decimal                @default(0) @db.Decimal(12, 2)
  priceChild       Decimal                @default(0) @db.Decimal(12, 2)
  priceInfant      Decimal                @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal                @db.Decimal(12, 2)
  paidAmount       Decimal                @default(0) @db.Decimal(12, 2)
  discount         Decimal                @default(0) @db.Decimal(12, 2)
  notes            String?
  bookingCustomers BookingCustomer[]
  serviceItems     BookingServiceItem[]
  invoices         Invoice[]
  vouchers         Voucher[]
  checkIns         CheckInRecord[]
  vendorCosts      VendorCostAllocation[]
  vendorPostings   VendorPosting[]
  postingRequests           PostingRequest[]
  confirmationRequests      BookingConfirmationRequest[]
  refunds                   BookingRefund[]
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
}

model BookingRefund {
  id                String       @id @default(uuid())
  bookingId         String
  booking           Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceItemId     String?
  vendorPostingId   String?
  customerAmount    Decimal      @db.Decimal(12, 2)
  vendorAmount      Decimal?     @db.Decimal(12, 2)
  currency          CurrencyCode @default(PKR)
  isVendorPosted    Boolean      @default(false)
  notes             String?
  journalEntryId    String?
  createdById       String
  createdBy         User         @relation("BookingRefundCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime     @default(now())
}

model BookingConfirmationRequest {
  id              String                           @id @default(uuid())
  bookingId       String
  booking         Booking                          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedBy     User                             @relation("BookingConfirmationRequestedBy", fields: [requestedById], references: [id])
  status          BookingConfirmationRequestStatus @default(PENDING)
  reviewedById    String?
  reviewedBy      User?                            @relation("BookingConfirmationReviewedBy", fields: [reviewedById], references: [id])
  rejectionReason String?
  createdAt       DateTime                         @default(now())
  reviewedAt      DateTime?
}

model BookingServiceItem {
  id          String       @id @default(uuid())
  bookingId   String
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceType ServiceType
  description String
  amount      Decimal      @db.Decimal(12, 2)
  costAmount  Decimal      @default(0) @db.Decimal(12, 2)
  vendorId    String?
  vendor      Vendor?      @relation(fields: [vendorId], references: [id])
  details     Json?
  createdAt   DateTime     @default(now())
}

model BookingCustomer {
  id         String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@unique([bookingId, customerId])
}

model Account {
  id           String        @id @default(uuid())
  name         String
  code         String        @unique
  type         AccountType
  balance      Decimal       @default(0) @db.Decimal(14, 2)
  balancePkr   Decimal       @default(0) @db.Decimal(14, 2)
  balanceSar   Decimal       @default(0) @db.Decimal(14, 2)
  description  String?
  currency     CurrencyCode  @default(PKR)
  isActive     Boolean       @default(true)
  customerId   String?       @unique
  customer     Customer?     @relation("CustomerAccount", fields: [customerId], references: [id])
  vendorId     String?       @unique
  vendor       Vendor?       @relation("VendorAccount", fields: [vendorId], references: [id])
  employeeId   String?       @unique
  employee     User?         @relation("EmployeeAccount", fields: [employeeId], references: [id])
  transactions Transaction[]
  expenses     Expense[]
  payments     Payment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model JournalEntry {
  id           String        @id @default(uuid())
  entryNumber  String        @unique
  date         DateTime      @default(now())
  description  String
  reference    String?
  notes        String?
  receiptPath  String?
  isDeleted    Boolean       @default(false)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Transaction {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal       @default(0) @db.Decimal(14, 2)
  credit         Decimal       @default(0) @db.Decimal(14, 2)
  currency       CurrencyCode  @default(PKR)
  exchangeRate   Decimal?      @db.Decimal(12, 4)
  amountPkr      Decimal?      @db.Decimal(14, 2)
  amountSar      Decimal?      @db.Decimal(14, 2)
  paymentMethod  PaymentMethod?
  remarks        String?
  attachmentPath String?
  description    String?
  createdAt      DateTime      @default(now())
}

model InvoiceTemplate {
  id        String   @id @default(uuid())
  name      String
  header    String   @db.Text
  footer    String   @db.Text
  terms     String?  @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  bookingId      String?
  booking        Booking?      @relation(fields: [bookingId], references: [id])
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  subtotal       Decimal       @db.Decimal(12, 2)
  tax            Decimal       @default(0) @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  confirmedAt    DateTime?
  journalEntryId String?
  approvalStatus InvoiceApprovalStatus @default(PENDING)
  approvedAt     DateTime?
  approvedById   String?
  approvedBy     User?                 @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])
  notes          String?
  shareToken     String?       @unique
  items          InvoiceItem[]
  payments       Payment[]
  vendorPostings VendorPosting[]
  vouchers       Voucher[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model InvoiceItem {
  id          String       @id @default(uuid())
  invoiceId   String
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int          @default(1)
  unitPrice   Decimal      @db.Decimal(12, 2)
  amount      Decimal      @db.Decimal(12, 2)
  costAmount  Decimal      @default(0) @db.Decimal(12, 2)
  serviceType ServiceType?
  vendorId    String?
  details     Json?
  vendorPostings VendorPosting[]
}

model Payment {
  id                 String                    @id @default(uuid())
  paymentNumber      String                    @unique
  invoiceId          String?
  invoice            Invoice?                  @relation(fields: [invoiceId], references: [id])
  accountId          String
  account            Account                   @relation(fields: [accountId], references: [id])
  amount             Decimal                   @db.Decimal(12, 2)
  currency           CurrencyCode              @default(PKR)
  exchangeRate       Decimal?                  @db.Decimal(12, 4)
  amountPkr          Decimal                   @default(0) @db.Decimal(12, 2)
  amountSar          Decimal?                  @db.Decimal(12, 2)
  method             PaymentMethod             @default(CASH)
  reference          String?
  notes              String?
  attachmentPath     String?
  verificationStatus PaymentVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  journalEntryId     String?
  paymentDate        DateTime                  @default(now())
  recordedById       String
  recordedBy         User                      @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  vouchers           Voucher[]
  createdAt          DateTime                  @default(now())
}

model Voucher {
  id               String        @id @default(uuid())
  voucherNumber    String        @unique
  bookingId        String?
  booking          Booking?      @relation(fields: [bookingId], references: [id])
  invoiceId        String?
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id])
  paymentId        String?
  payment          Payment?      @relation(fields: [paymentId], references: [id])
  voucherFormat    VoucherFormat @default(HOTEL)
  hotelName        String?
  checkInDate      DateTime?
  checkOutDate     DateTime?
  guestName        String
  roomDetails      String?
  transportDetails Json?
  paymentStatus    String?
  remainingBalance Decimal?      @db.Decimal(12, 2)
  status           VoucherStatus @default(DRAFT)
  issuedAt         DateTime?
  sharedAt         DateTime?
  shareToken       String?       @unique
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model CheckInRecord {
  id              String      @id @default(uuid())
  bookingId       String?
  booking         Booking?    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  invoiceId       String?
  scheduleType    ServiceType @default(HOTEL)
  hotelName       String?
  checkInDate     DateTime?
  transportDate   DateTime?
  pickupLocation  String?
  dropoffLocation String?
  guestName       String?
  roomDetails     String?
  vendorPosted    Boolean     @default(false)
  reminderSent    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model VendorPosting {
  id             String              @id @default(uuid())
  invoiceId      String?
  invoice        Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  bookingId      String?
  booking        Booking?            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  invoiceItemId  String?
  invoiceItem    InvoiceItem?        @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  vendorId       String?
  vendor         Vendor?             @relation(fields: [vendorId], references: [id])
  serviceType    ServiceType
  description    String
  expectedCost   Decimal             @db.Decimal(12, 2)
  actualCost     Decimal?            @db.Decimal(12, 2)
  currency       CurrencyCode        @default(PKR)
  exchangeRate   Decimal?            @db.Decimal(12, 4)
  postingType    VendorPostingType   @default(PENDING)
  status         VendorPostingStatus @default(PENDING)
  dueDate        DateTime?
  reminderSent   Boolean             @default(false)
  unpostedJournalEntryId String?
  journalEntryId String?
  postedAt       DateTime?
  postingRequests PostingRequest[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model PostingRequest {
  id              String               @id @default(uuid())
  bookingId       String
  booking         Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendorPostingId String
  vendorPosting   VendorPosting        @relation(fields: [vendorPostingId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedBy     User                 @relation("PostingRequestRequestedBy", fields: [requestedById], references: [id])
  status          PostingRequestStatus @default(PENDING)
  reviewedById    String?
  reviewedBy      User?                @relation("PostingRequestReviewedBy", fields: [reviewedById], references: [id])
  rejectionReason String?
  createdAt       DateTime             @default(now())
  reviewedAt      DateTime?
}

model VendorCostAllocation {
  id             String      @id @default(uuid())
  bookingId      String
  booking        Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendorId       String
  vendor         Vendor      @relation(fields: [vendorId], references: [id])
  serviceType    ServiceType
  amount         Decimal     @db.Decimal(12, 2)
  description    String?
  journalEntryId String?
  createdAt      DateTime    @default(now())
}

model DocumentSequence {
  id        String   @id @default("booking")
  nextValue Int      @default(1)
  updatedAt DateTime @updatedAt
}

model Expense {
  id            String          @id @default(uuid())
  expenseNumber String          @unique
  category      ExpenseCategory
  accountId     String
  account       Account         @relation(fields: [accountId], references: [id])
  amount        Decimal         @db.Decimal(12, 2)
  currency      CurrencyCode    @default(PKR)
  exchangeRate  Decimal?        @db.Decimal(12, 4)
  amountPkr     Decimal         @default(0) @db.Decimal(12, 2)
  amountSar     Decimal         @default(0) @db.Decimal(12, 2)
  description   String
  vendor        String?
  vendorId      String?
  vendorRef     Vendor?         @relation(fields: [vendorId], references: [id])
  bookingId     String?
  receiptPath   String?
  expenseDate   DateTime        @default(now())
  createdById   String
  createdBy     User            @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model IncomeEntry {
  id          String         @id @default(uuid())
  entryNumber String         @unique
  category    IncomeCategory
  amount      Decimal        @db.Decimal(12, 2)
  description String
  reference   String?
  receiptPath String?
  entryDate   DateTime       @default(now())
  createdAt   DateTime       @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
}

model ActivityLog {
  id         String         @id @default(uuid())
  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     ActivityAction
  entity     String
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime       @default(now())
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt
}

model DeletedRecord {
  id         String   @id @default(uuid())
  entity     String
  entityId   String
  data       String   @db.LongText
  deletedBy  String?
  deletedAt  DateTime @default(now())
}
